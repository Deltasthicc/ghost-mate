# Host server
APP_NAME="Autonomous CoreXY Chess Robot"
HOST=127.0.0.1
PORT=8000
APP_DEBUG=false

# Set this true only when you need SQLAlchemy echo output. It is independent
# of APP_DEBUG so dev mode doesn't spam SQL on every state push.
SQL_ECHO=false

# Hardware
SERIAL_PORT=/dev/serial/by-id/usb-Teensyduino_USB_Serial_6634680-if00
SERIAL_BAUD=115200
SERIAL_MOCK=true
COMMAND_TIMEOUT_S=5.0

# Board geometry
SQUARE_SIZE_MM=50.0
BOARD_ORIGIN_X_MM=0.0
BOARD_ORIGIN_Y_MM=0.0
CAPTURE_TRAY_LEFT_X_MM=-60.0
CAPTURE_TRAY_RIGHT_X_MM=460.0

# Chess engine
STOCKFISH_PATH=stockfish
ENGINE_MOVE_TIME_S=1.0
ENGINE_EVAL_TIME_S=0.12
ENGINE_LIVE_PUSH_ENABLED=true
ENGINE_LIVE_INTERVAL_S=1.0
ENGINE_LIVE_MULTIPV=5
ENGINE_LIVE_MAX_DEPTH=24
ENGINE_LIVE_SEARCH_TIME_S=2.0
# Leave ENGINE_THREADS unset to default to (cpu_count - 1).
# ENGINE_THREADS=3
ENGINE_HASH_MB=128
# Optional Stockfish skill cap (0..20). Unset = full strength.
# ENGINE_SKILL_LEVEL=12

# Optional LLM coach. Leave disabled unless you have an OpenAI-compatible API key.
LLM_COACH_ENABLED=false
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_S=20.0
LLM_MAX_TOKENS=700

# Database
DATABASE_URL=sqlite:///data/db/chess_robot.db

# WebSocket / event bus tuning
WS_MAX_QUEUE=256
STATE_THROTTLE_MS=16

# Lichess optional
LICHESS_TOKEN=
LICHESS_BOT_TOKEN=
