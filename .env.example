# Host server
APP_NAME="Autonomous CoreXY Chess Robot"
HOST=127.0.0.1
PORT=8000
APP_DEBUG=true

# Hardware
SERIAL_PORT=COM3
SERIAL_BAUD=115200
SERIAL_MOCK=true
COMMAND_TIMEOUT_S=5.0

# Board geometry
SQUARE_SIZE_MM=50.0
BOARD_ORIGIN_X_MM=0.0
BOARD_ORIGIN_Y_MM=0.0
CAPTURE_TRAY_LEFT_X_MM=-60.0
CAPTURE_TRAY_RIGHT_X_MM=460.0

# Chess engine
STOCKFISH_PATH=stockfish
ENGINE_MOVE_TIME_S=1.0

# Database
DATABASE_URL=sqlite:///data/db/chess_robot.db

# Lichess optional
LICHESS_TOKEN=
LICHESS_BOT_TOKEN=
